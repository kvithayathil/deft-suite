{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {
    "no-unused-vars": "warn",
    "typescript/no-explicit-any": "off"
  },
  "ignorePatterns": ["dist/**", "coverage/**", "reports/**", "node_modules/**"]
}
